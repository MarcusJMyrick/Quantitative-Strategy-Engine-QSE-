# Copy this file to .env and fill in your personal API key
ALPHA_VANTAGE_API_KEY="YOUR_KEY_HERE"
# Alpaca paper-trading credentials (E2/E3) - official variable names.
# Used by AlpacaExecutionHandler::from_env and the alpaca_smoke tool.
APCA_API_KEY_ID="YOUR_PAPER_KEY_ID"
APCA_API_SECRET_KEY="YOUR_PAPER_SECRET"
